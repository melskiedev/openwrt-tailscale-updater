render_dashboard() {
    # Read POSIX timezone string from UCI (e.g. PST-8 means GMT+8)
    TZ_POSIX="$(uci get system.@system[0].timezone 2>/dev/null || true)"
    NOW=""

    # Calculate GMT offset from POSIX string (sign is inverted in POSIX notation)
    GMT_LABEL="UTC"
    if [ -n "$TZ_POSIX" ]; then
        OFFSET="$(echo "$TZ_POSIX" | sed -n 's/^[A-Za-z]*\([+-][0-9]*\).*/\1/p')"
        if [ -n "$OFFSET" ]; then
            case "$OFFSET" in
                -*) GMT_LABEL="GMT+${OFFSET#-}" ;;
                +*) GMT_LABEL="GMT-${OFFSET#+}" ;;
                *)  GMT_LABEL="GMT" ;;
            esac
        fi
        NOW="$(TZ="$TZ_POSIX" date "+%a %b %d %Y %I:%M:%S %p $GMT_LABEL" 2>/dev/null || true)"
    fi

    [ -n "$NOW" ] || NOW="$(date '+%a %b %d %Y %I:%M:%S %p UTC' 2>/dev/null || true)"
    [ -n "$NOW" ] || NOW="time-unavailable"
    MODEL="$(cat /tmp/sysinfo/model 2>/dev/null || echo "${OPENWRT_TARGET:-unknown}")"
    FW_VER="${OPENWRT_RELEASE:-unknown}"
    LAN_IP="$(ip -4 addr show br-lan 2>/dev/null | awk '/inet / {print $2}' | head -n 1)"
    [ -n "$LAN_IP" ] || LAN_IP="unknown"
    TS_VER="$(tailscale version 2>/dev/null | awk 'NR==1 {print $1}')"
    [ -n "$TS_VER" ] || TS_VER="not installed"

    hr
    printf '\n'
    printf "  ${UI_TITLE}openwrt-tailscale-updater${C_RESET}\n"
    printf '\n'
    printf "  Model:     %s\n" "$MODEL"
    printf "  Firmware:  OpenWrt %s\n" "$FW_VER"
    printf "  LAN:       %s\n" "$LAN_IP"
    printf "  Tailscale: %s\n" "$TS_VER"
    printf "  Time:      %s\n" "$NOW"
    printf "  Theme:     %s\n" "$THEME_NAME"
    printf '\n'
}

