        read -r CHOICE

        case "$CHOICE" in
            1) TRACK="stable";            return 0 ;;
            2) TRACK="unstable";          return 0 ;;
            3) TRACK="release-candidate"; return 0 ;;
            4) SELECT_RELEASE=1;          return 0 ;;
            5) ROLLBACK=1;                return 0 ;;
            6) DELETE_BACKUP=1;           return 0 ;;
            t|T) show_theme_menu ;;
            r|R) reset_menu_defaults; ui_ok "Defaults restored." ;;
            a|A) show_about ;;
            e|E|c|C) log "Cancelled by user."; exit 0 ;;
            *) ui_warn "Please select 1-6, e, t, r, or a." ;;
        esac
    done
}

main() {
    theme_init
    parse_args "$@"

    # Load OpenWrt metadata early so the dashboard has firmware info
    if [ -f /etc/openwrt_release ]; then
        read_openwrt_release
    fi

    # Show main menu when no action flags are passed and running interactively
    NO_ACTION_FLAGS=1
    [ "$FORCE" -eq 1 ]              && NO_ACTION_FLAGS=0
    [ "$DRY_RUN" -eq 1 ]            && NO_ACTION_FLAGS=0
    [ "$ROLLBACK" -eq 1 ]           && NO_ACTION_FLAGS=0
    [ "$DELETE_BACKUP" -eq 1 ]      && NO_ACTION_FLAGS=0
    [ "$SELECT_RELEASE" -eq 1 ]     && NO_ACTION_FLAGS=0
    [ "$MIGRATE_MULTICALL" -eq 1 ]  && NO_ACTION_FLAGS=0
    [ "$TRACK" != "stable" ]        && NO_ACTION_FLAGS=0

    if [ "$NO_ACTION_FLAGS" -eq 1 ] && [ "$NON_INTERACTIVE" -eq 0 ] && is_tty; then
        show_main_menu
    fi

    # Rollback and delete-backup only need path detection, not full preflight
    if [ "$ROLLBACK" -eq 1 ] || [ "$DELETE_BACKUP" -eq 1 ]; then
        [ -n "${OPENWRT_RELEASE:-}" ] || read_openwrt_release
        detect_pkg_manager
        detect_arch
        command -v readlink >/dev/null 2>&1 || die "readlink is missing"
        readlink -f / >/dev/null 2>&1 || die "readlink -f is not supported on this system"
        detect_tailscale_paths
        detect_tailscaled_service
        if [ "$ROLLBACK" -eq 1 ]; then
            do_rollback
        else
            do_delete_backup
        fi
        exit 0
    fi

    preflight
    current_version
    interactive_preflight_display

    if [ "$MIGRATE_MULTICALL" -eq 1 ]; then
        validate_migration_preconditions
    fi

    find_latest_release

    if [ "$DRY_RUN" -eq 1 ]; then
        hr
        ui_step "Dry run only. No changes made."
        box \
            "Installed version: $CURRENT_VERSION ($CURRENT_TRACK)" \
            "Target track:      $TRACK" \
            "Static tarball:    $LATEST_VERSION" \
            "GitHub latest:     $GITHUB_LATEST_VERSION" \
            "Archive:           $ARCHIVE_NAME" \
            "tailscale:         $TAILSCALE_REAL" \
            "tailscaled:        $TAILSCALED_REAL" \
            "Init script:       $TAILSCALED_INIT"
        cleanup
        exit 0
    fi

    if [ "$CURRENT_VERSION" = "$LATEST_VERSION" ] && [ "$FORCE" -ne 1 ] && [ "$MIGRATE_MULTICALL" -ne 1 ] && [ "$SELECT_RELEASE" -ne 1 ]; then
        ui_ok "Already on latest version ($CURRENT_VERSION). Use --force to reinstall."
        cleanup
        exit 0
    fi

    if [ "$MIGRATE_MULTICALL" -eq 1 ]; then
        interactive_migration_summary
    else
        interactive_update_summary
    fi

    backup_current
    download_release
    stop_tailscaled

    if [ "$MIGRATE_MULTICALL" -eq 1 ]; then
        remove_apk_package
        ensure_kmod_tun
        ensure_init_compat_symlink
    fi

    install_binaries
    start_tailscaled
    verify_install
    ensure_sysupgrade_persistence
    cleanup

    if [ "$MIGRATE_MULTICALL" -eq 1 ]; then
        hr
        ui_ok "Migration complete. This router is now running upstream Tailscale $LATEST_VERSION."
        ui_ok "apk no longer manages Tailscale on this router."
        ui_step "Use this script for future updates."
        if apk list --installed 2>/dev/null | grep -qi '^tailscale'; then
            ui_warn "apk still shows Tailscale as installed. Check manually with: apk list --installed | grep tailscale"
        else
            ui_ok "Confirmed: Tailscale is no longer apk-managed on this router."
        fi
    else
        hr
        ui_ok "Update complete. Tailscale $LATEST_VERSION is now running."
    fi
}

main "$@"
